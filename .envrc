if [[ -z "${CODEX_HOME:-}" ]]; then
  if [[ (-d "$HOME/.codex" && -w "$HOME/.codex") || (! -e "$HOME/.codex" && -w "$HOME") ]]; then
    export CODEX_HOME="$HOME/.codex"
  elif [[ -d "$HOME/.codex/automations" && -w "$HOME/.codex/automations" ]]; then
    export CODEX_HOME="$HOME/.codex/automations"
  else
    export CODEX_HOME="$PWD/.codex"
  fi
fi
export NEXT_TELEMETRY_DISABLED=1

export VOLTA_HOME="${VOLTA_HOME:-$HOME/.volta}"
if [[ -d "$VOLTA_HOME/bin" ]]; then
  PATH_add "$VOLTA_HOME/bin"
fi

if declare -F use_nvm >/dev/null 2>&1; then
  use_nvm >/dev/null 2>&1 || true
fi

PATH_add node_modules/.bin
