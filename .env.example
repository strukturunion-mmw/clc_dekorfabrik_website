# Runtime secrets are NOT stored in this file.
# Store them in Google Secret Manager and inject them into the Cloud Run
# service as environment variables via the deploy workflow or the Cloud Run
# service configuration. This file exists only to document which variables
# an application instance expects at runtime.
#
# Local development: create a .env.local (gitignored) alongside this file
# when a variable is needed during `npm run dev`.
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL=
MAILJET_FROM_NAME="Dekorfabrik Website"
INQUIRY_TO_EMAIL=inquiries@dekorfabrik.de
MAILJET_SANDBOX_MODE=false
